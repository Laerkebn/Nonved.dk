---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Home | My Portfolio">
<!-- HERO -->
<div class="min-h-screen flex flex-col justify-between text-center lg:text-left px-5 sm:px-10 lg:px-20 pt-5">
  <h1
    class="text-4xl sm:text-5xl lg:text-8xl xl:text-8xl font-black"
    style="text-shadow: 3px 3px 0 #29cb17, -2px -2px 0 #0a4b09, 3px -2px 0 #406f40, -2px 3px 0 #75db77;"
  >
    Exploring ideas through design, motion and digital experiments.
  </h1>

  <!-- PIL -->
  <div class="flex justify-center mb-60">
    <img
      src="/Billeder/PILNED.svg"
      alt="Scroll ned"
      class="w-10 h-full transition-transform duration-700 hover:scale-110 cursor-pointer"
     onclick="const el = document.getElementById('about'); window.scrollTo({ top: el.offsetTop - 80, behavior: 'smooth' })"
    />
  </div>
</div>

<!-- ABOUT ME + PROJECTS GRID -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-20">

  <!-- Fælles header -->
  <div id="about" class="text-center mb-16 lg:mb-24">
    <h1
      class="text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-black mb-6"
      style="text-shadow: 3px 3px 0 #29cb17, -2px -2px 0 #0a4b09, 3px -2px 0 #406f40, -2px 3px 0 #75db77;"
    >
      About Me & Projects
    </h1>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

    <!-- ABOUT ME -->
    <div class="bg-gradient-to-br from-black via-[#1a1010] to-black rounded-2xl overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.9)] border border-gray-800 hover:border-lime-500/30 transition-all duration-500">
      <div class="relative overflow-hidden h-[300px] group">
        <img
          src="/Billeder/pb.JPG"
          alt="Picture of me"
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-black/60 to-transparent"></div>
      </div>
      <div class="p-8 lg:p-10 flex flex-col justify-center">
        <h2 class="text-4xl lg:text-5xl font-bold text-[#29cb17] mb-6">About me</h2>
        <div class="space-y-4 text-lg text-gray-200 leading-relaxed mb-8">
           <p>
    Hello, my name is Lærke. I'm a Danish woman studying Visual Communication with a specialization in Coded Design. I work in the intersection of design and code, with a particular interest in creating digital experiences that feel playful, aesthetic, and human. I'd love for you to get to know me a little better.</p>
        </div>
        
        <a
          href="/about"
          class="inline-block bg-[#29cb17] hover:bg-lime-700 text-white font-bold py-4 px-8 rounded-xl transition-all duration-300 transform hover:scale-105 w-fit"
        >
          Read More
        </a>
      </div>
    </div>

    <!-- PROJECT read more -->
    <div class="bg-gradient-to-br from-black via-[#1a1010] to-black rounded-2xl overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.9)] border border-gray-800 hover:border-lime-500/30 transition-all duration-500">
      <div class="relative overflow-hidden h-[300px] group">
        <img
          src="/Billeder/PH.png"
          alt="Haunted House Tour"
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-black/60 to-transparent"></div>
      </div>
      <div class="p-8 lg:p-10 flex flex-col justify-center">
        <h2 class="text-4xl lg:text-5xl font-bold text-[#29cb17] mb-6">My Projects</h2>
        <div class="space-y-4 text-lg text-gray-200 leading-relaxed mb-8">
          <p>
         I love creating — from interactive code experiments to visual storytelling. My work lives in the space between design, code, and human experience, driven by playfulness, aesthetics, and atmosphere. Every project starts with curiosity and a desire to create something that feels human. Click below to explore my work.</p>
       
        </div>
           <a
          href="/projects"
          class="inline-block bg-[#29cb17] hover:bg-lime-700 text-white font-bold py-4 px-8 rounded-xl transition-all duration-300 transform hover:scale-105 w-fit"
        >
          Read More
        </a>
      </div>
    </div>

  </div>

  <!-- Footer -->
<footer class="site-footer mt-10">
  <div class="footer-box">
    <p>© Lærke Buch Nonved portfolio</p>
  </div>
</footer>

</div>

  <script is:inline>
    const gallery = document.getElementById("wweGallery");
    const button = document.getElementById("showGalleryButton");
    const slider = document.getElementById("wweSlider");
    const next = document.getElementById("nextSlide");
    const prev = document.getElementById("prevSlide");
    const indicators = document.getElementById("slideIndicators");

    if (gallery && button && slider && next && prev && indicators) {
      let index = 0;
      const slides = slider.children.length;

      for (let i = 0; i < slides; i++) {
        const dot = document.createElement("button");
        dot.className = "w-3 h-3 rounded-full bg-gray-500 hover:bg-lime-500 transition-all duration-300";
        dot.onclick = () => goToSlide(i);
        indicators.appendChild(dot);
      }

      function updateIndicators() {
        Array.from(indicators.children).forEach((dot, i) => {
          dot.className = i === index
            ? "w-3 h-3 rounded-full bg-lime-500 scale-125 transition-all duration-300"
            : "w-3 h-3 rounded-full bg-gray-500 hover:bg-lime-500 transition-all duration-300";
        });
      }

      function goToSlide(n) {
        index = n;
        slider.style.transform = `translateX(-${index * 100}%)`;
        updateIndicators();
      }

      button.addEventListener("click", () => {
        gallery.classList.toggle("hidden");
        button.innerHTML = gallery.classList.contains("hidden")
          ? "📸 See Latest Photos"
          : "✖️ Hide Photos";
      });

      next.addEventListener("click", () => {
        index = (index + 1) % slides;
        goToSlide(index);
      });

      prev.addEventListener("click", () => {
        index = (index - 1 + slides) % slides;
        goToSlide(index);
      });

      updateIndicators();
    }
  </script>

</Layout>