---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Home | My Portfolio">

  <div class="page-wrapper">

    <!-- HERO -->
    <div class="proj-hero fade-in">
      <div class="proj-hero-content" style="position: absolute; top: 35%; left: 50%; transform: translate(-50%, -50%);">
        <h1
          class="text-3xl sm:text-5xl font-black text-left"
          style="text-shadow: 3px 3px 0 #29cb17, -2px -2px 0 #0a4b09, 3px -2px 0 #406f40, -2px 3px 0 #75db77;"
        >
          Exploring ideas through design, motion and digital experiments.
        </h1>
      </div>
    </div>

<footer class="site-footer -mt-20">
      <div class="footer-box">
        <p>© Lærke Buch Nonved portfolio</p>
      </div>
    </footer>

  </div>

</Layout>