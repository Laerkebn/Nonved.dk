---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="ÅBEN | My Portfolio" page="projects">

  <div class="page-wrapper">

    <!-- Tilbage knap -->
    <div class="fade-in" style="padding-top: 2rem;">
      <a href="/projects" class="proj-back-btn">← Projects</a>
    </div>

    <!-- TITEL -->
    <div style="
      font-size: clamp(1rem, 8vw, 15rem);
      font-weight: 900;
      line-height: 0.85;
      letter-spacing: -0.05em;
      color: transparent;
      -webkit-text-stroke: 2px #29cb17;
      opacity: 0.6;
      pointer-events: none;
      word-break: break-word;
      text-align: center;
      margin-top: 2rem;
      font-family: ui-sans-serif, system-ui, sans-serif;
    ">ÅBEN</div>

    <!-- Tags -->
    <div class="fade-in" style="display: flex; gap: 0.5rem; flex-wrap: wrap; justify-content: center; padding: 1rem 0 2rem; opacity: 0.6;">
      <span class="proj-tag whitespace-nowrap">Chaikin Curves</span>
      <span class="proj-tag whitespace-nowrap">Asset generator</span>
      <span class="proj-tag whitespace-nowrap">Branding & identity</span>
      <span class="proj-tag whitespace-nowrap">JavaScript</span>
      <span class="proj-tag whitespace-nowrap">Astro</span>
    </div>

    <!-- VIDEO -->
    <div class="proj-gallery-full rounded-2xl overflow-hidden border border-[#272425] mb-8 fade-in">
      <video autoplay muted loop playsinline style="width: 100%; height: 100%; object-fit: cover; transform: scale(1.0) translateX(7%);">
        <source src="/Billeder/AABEN/AABEN2.mp4" type="video/mp4" />
      </video>
    </div>

    <div id="projekt">

      <div class="fade-in mb-12">
        <p class="text-base sm:text-xl text-gray-200 leading-relaxed">
          Hvor meget tekst ville du gerne have her?
        </p>
      </div>

      <div class="fade-in mb-8">
        <p class="text-base sm:text-xl text-gray-200 leading-relaxed">
          Beskrivelse af mit projekt...
        </p>
      </div>

      <!-- BILLEDKARUSEL -->
      <div class="relative overflow-hidden rounded-xl fade-in mb-8">
        <div id="karusel" class="flex transition-transform duration-500 ease-in-out">
          <img src="/Billeder/BILLEDE1.jpg" class="karusel-billede flex-shrink-0 object-cover rounded-xl cursor-pointer hover:opacity-80 transition-opacity duration-300" style="height: 400px;" />
          <img src="/Billeder/BILLEDE2.jpg" class="karusel-billede flex-shrink-0 object-cover rounded-xl cursor-pointer hover:opacity-80 transition-opacity duration-300" style="height: 400px;" />
          <img src="/Billeder/BILLEDE3.jpg" class="karusel-billede flex-shrink-0 object-cover rounded-xl cursor-pointer hover:opacity-80 transition-opacity duration-300" style="height: 400px;" />
        </div>
        <button id="pil-venstre" class="absolute left-3 top-1/2 -translate-y-1/2 bg-black/60 hover:bg-black text-[#29cb17] text-2xl px-3 py-1 rounded-full">‹</button>
        <button id="pil-højre" class="absolute right-3 top-1/2 -translate-y-1/2 bg-black/60 hover:bg-black text-[#29cb17] text-2xl px-3 py-1 rounded-full">›</button>
        <div id="prikker" class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-2"></div>
      </div>

      <div class="fade-in mb-8">
        <p class="text-base sm:text-xl text-gray-200 leading-relaxed">
          Beskrivelse af mit projekt...
        </p>
      </div>

    </div>

    <!-- LIGHTBOX -->
    <div id="lightbox" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.9); z-index:1000; align-items:center; justify-content:center; cursor:zoom-out;">
      <img id="lightbox-img" src="" style="max-width:90vw; max-height:90vh; object-fit:contain; border-radius:1rem;" />
    </div>

    <footer class="site-footer mt-10">
      <div class="footer-box">
        <p>© Lærke Buch Nonved portfolio</p>
      </div>
    </footer>

  </div>

</Layout>

<script is:inline>
  function initAaben() {
    const visPerSlide = window.innerWidth < 640 ? 1 : 3;
    let aktuel = 0;
    const billeder = document.querySelectorAll('.karusel-billede');
    const antalSlides = Math.ceil(billeder.length / visPerSlide);
    const prikContainer = document.getElementById('prikker');
    const karusel = document.getElementById('karusel');

    if (!karusel) return;

    billeder.forEach(img => {
      img.style.width = `${100 / visPerSlide}%`;
    });

    prikContainer.innerHTML = '';

    function gåTil(index) {
      aktuel = (index + antalSlides) % antalSlides;
      karusel.style.transform = `translateX(-${aktuel * 100}%)`;
      document.querySelectorAll('#prikker div').forEach((p, i) => {
        p.style.background = i === aktuel ? '#29cb17' : 'rgba(255,255,255,0.4)';
      });
    }

    for (let i = 0; i < antalSlides; i++) {
      const prik = document.createElement('div');
      prik.style.cssText = `width:8px; height:8px; border-radius:50%; cursor:pointer; transition:background 0.3s; background:${i === 0 ? '#29cb17' : 'rgba(255,255,255,0.4)'}`;
      prik.addEventListener('click', () => gåTil(i));
      prikContainer.appendChild(prik);
    }

    document.getElementById('pil-venstre').addEventListener('click', () => gåTil(aktuel - 1));
    document.getElementById('pil-højre').addEventListener('click', () => gåTil(aktuel + 1));

    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img');

    billeder.forEach(img => {
      img.addEventListener('click', () => {
        lightboxImg.src = img.src;
        lightbox.style.display = 'flex';
      });
    });

    lightbox.addEventListener('click', () => {
      lightbox.style.display = 'none';
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') lightbox.style.display = 'none';
    });
  }

  document.addEventListener('astro:page-load', initAaben);
  document.addEventListener('DOMContentLoaded', initAaben);
</script>