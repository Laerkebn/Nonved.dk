---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---
<Layout title="Contact | My Portfolio" page="contact">

  <div class="page-wrapper">

    <!-- HERO -->
    <div class="proj-hero fade-in" style="min-height: 60vh;">
      <div class="proj-title">CONTACT</div>
    </div>

 <!-- kontakt -->
    <div id="contact-content" class="max-w-xl mx-auto fade-in -mt-70">
      <div class=" overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.9)] border border-[#272425]">
        <nav class="bg-black/80 text-[#29cb17] flex flex-col items-center gap-7 py-10 px-10 uppercase tracking-widest font-semibold">
          <div class="flex items-center gap-3">
            <span>Instagram:</span>
            <a href="https://www.instagram.com/nonved.dk" target="_blank" rel="noopener noreferrer" class="hover:text-purple-600 transition duration-300 hover:scale-110">@Nonved.dk</a>
          </div>
          <div class="flex items-center gap-3">
            <span>Mail:</span>
            <a href="mailto:Lærke@nonved.dk" class="hover:text-purple-600 transition duration-300 hover:scale-110">Lærke@nonved.dk</a>
          </div>
          <div class="flex items-center gap-3">
            <span>LinkedIn:</span>
            <a href="https://www.linkedin.com/in/l%C3%A6rke-buch-nonved-553332356/" target="_blank" rel="noopener noreferrer" class="hover:text-purple-600 transition duration-300 hover:scale-110">Lærke Buch Nonved</a>
          </div>
        </nav>
      </div>
    </div>


<footer class="site-footer mt-100">
      <div class="footer-box">
        <p>© Lærke Buch Nonved portfolio</p>
      </div>
    </footer>

  </div>

</Layout>