---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Contact | My Portfolio">

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-20">

    <div class="text-center mb-16 lg:mb-24">
      <h1
        class="text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-black mb-6"
        style="text-shadow: 3px 3px 0 #29cb17, -2px -2px 0 #0a4b09, 3px -2px 0 #406f40, -2px 3px 0 #75db77;"
      >
        Contact Me
      </h1>
      <p class="text-xl lg:text-2xl text-[#29cb17] max-w-4xl mx-auto leading-relaxed">
        Feel free to reach out or follow me on social media
      </p>
    </div>

    <div class="max-w-xl mx-auto">
      <div class="rounded-2xl overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.9)] border border-[#272425] transition-all duration-500">
        <nav class="bg-black/80 text-[#29cb17] flex flex-col items-center gap-7 py-10 px-10 uppercase tracking-widest font-semibold">

          <div class="flex items-center gap-3">
            <span>Instagram:</span>
            <a
              href="https://www.instagram.com/nonved.dk"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-purple-600 transition duration-300 hover:scale-110"
            >
              @Nonved.dk
            </a>
          </div>

          <div class="flex items-center gap-3">
            <span>Mail:</span>
            <a
              href="mailto:Lærke@nonved.dk"
              class="hover:text-purple-600 transition duration-300 hover:scale-110"
            >
              Lærke@nonved.dk
            </a>
          </div>

          <div class="flex items-center gap-3">
            <span>LinkedIn:</span>
            <a
              href="https://www.linkedin.com/in/l%C3%A6rke-buch-nonved-553332356/"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-purple-600 transition duration-300 hover:scale-110"
            >
              Lærke Buch Nonved
            </a>
          </div>

        </nav>
      </div>
    </div>

    <!-- Footer -->
    <footer class="site-footer mt-10">
      <div class="footer-box">
        <p>© Lærke Buch Nonved portfolio</p>
      </div>
    </footer>

  </div>

</Layout>