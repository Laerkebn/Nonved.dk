---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---
<Layout title="Contact | My Portfolio">

    <div class="text-center  mb-16 lg:mb-24">
        <h1
          class="text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-black pt-5 mb-6"
          style="text-shadow: 3px 3px 0 #29cb17, -2px -2px 0 #0a4b09, 3px -2px 0 #406f40, -2px 3px 0 #75db77;"
        >
          Contact Me
        </h1>
  <p class="text-xl lg:text-2xl text-[#29cb17] max-w-4xl mx-auto leading-relaxed">
          Feel free to reach out or follow me on social media
        </p>
      </div>

  <div class=" flex items-center justify-center px-5">
    
    <nav
      class="bg-[#272425] text-[#29cb17] w-full max-w-xl flex flex-col items-center gap-7 py-4 px-10 rounded-xl shadow-lg uppercase tracking-widest font-semibold"
    >
      <div class="flex items-center gap-3">
        <span>Instagram:</span>
        <a 
          href="https://www.instagram.com/nonved.dk" 
          target="_blank" 
          rel="noopener noreferrer"
          class="hover:text-purple-600 transition duration-300 hover:scale-110"
        >
          @Nonved.dk
        </a>
      </div>

      <div class="flex items-center gap-3">
        <span>Mail:</span>
        <a 
          href="mailto:Lærke@nonved.dk"
          class="hover:text-purple-600 transition duration-300 hover:scale-110"
        >
          Lærke@nonved.dk
        </a>
      </div>

      <div class="flex items-center gap-3">
        <span>LinkedIn:</span>
        <a 
          href="https://www.linkedin.com/in/l%C3%A6rke-buch-nonved-553332356/" 
          target="_blank" 
          rel="noopener noreferrer"
          class="hover:text-purple-600 transition duration-300 hover:scale-110"
        >
          Lærke Buch Nonved
        </a>
      </div>

    </nav>

  </div>
          <!-- Footer -->
<footer class="site-footer mt-10">
  <div class="footer-box">
    <p>© Lærke Buch Nonved portfolio</p>
  </div>
</footer>
</Layout>