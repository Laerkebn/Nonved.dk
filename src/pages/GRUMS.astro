---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="GRUMS | My Portfolio" page="projects">

   <div class="page-wrapper">

   <div class="fade-in" style="position: absolute; top: 4rem; left: 2rem; z-index: 20;">
  <a href="/projects" class="proj-back-btn">← Projects</a>
</div>

    <!-- HERO -->
    <div class="proj-hero fade-in">
      <div class="proj-title">GRUMS</div>

       <span class="proj-tag whitespace-nowrap" style="position: absolute; top: 40%; left: 50%; transform: translateX(-50%);">Branding & identity</span>
    </div>

     <div id="projekter" class=" -mt-120">

      <div class="proj-gallery-full rounded-2xl overflow-hidden border border-[#272425] mb-2 fade-in">
        <video autoplay muted loop playsinline style="width: 100%; height: 100%;">
          <source src="/Billeder/GRUMS/GRUMS.mp4" type="video/mp4" />
        </video>
      </div>

      <div class="py-16 px-4 sm:px-0 fade-in">
        <div class="proj-text-block mx-auto text-center">
          <p class="text-xl text-gray-200 leading-relaxed">
         Hvor meget tekst ville du gerne have her?</p>
        </div>
      </div>

    </div>

    <footer class="site-footer mt-10">
      <div class="footer-box">
        <p>© Lærke Buch Nonved portfolio</p>
      </div>
    </footer>

  </div>

</Layout>