---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Projects | My Portfolio" page="projects">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-20">

    <!-- Header -->
    <div class="text-center mb-16 lg:mb-24">
      <h1
        class="text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-black mb-6"
        style="text-shadow: 3px 3px 0 #29cb17, -2px -2px 0 #0a4b09, 3px -2px 0 #406f40, -2px 3px 0 #75db77;"
      >
        My Projects
      </h1>
      <p class="text-xl lg:text-2xl text-[#29cb17] max-w-4xl mx-auto leading-relaxed">
        Stay updated on my latest projects — from art to branding.
      </p>
    </div>

    <!-- ROW 1 -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">

      <!-- PROJECT 1 -->
      <div class="rounded-2xl overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.9)] border border-[#272425] transition-all duration-500">
        <div class="relative overflow-hidden h-[300px]">
          <img src="/Billeder/GRUMS/GRUMSSTART.png" alt="Project 1" class="w-full h-full object-contain bg-black/60" />
        </div>
        <div class="p-8 lg:p-10 flex flex-col justify-center bg-black/80">
          <h2 class="text-4xl lg:text-5xl font-bold text-[#29cb17] mb-6">Project nr. 1</h2>
          <div class="space-y-4 text-lg text-gray-200 leading-relaxed mb-8">
            <p><strong class="text-[#29cb17]">Fragments of Silence</strong> is a conceptual art project exploring the tension between chaos and stillness in modern digital life.</p>
            <p>The work combines digital collage, 3D elements, and motion-based experimentation to create a fragmented visual narrative where broken lines and visual glitches become a language.</p>
          </div>
          <a href="/GRUMS" class="inline-block bg-[#29cb17] hover:bg-lime-700 text-white font-bold py-4 px-8 rounded-xl transition-all duration-300 transform hover:scale-105 w-fit">Read More</a>
        </div>
      </div>

