---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Projects | My Portfolio" page="projects">

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-20">

    <!-- HERO -->
    <div class="proj-hero fade-in">
      <div class="proj-title" style="font-size: clamp(3rem, 15vw, 18rem);">PROJECTS</div>

     <span class="proj-tag whitespace-nowrap" style="position: absolute; top: 15%; left: 50%; transform: translateX(-50%);">My work</span>

      <div class="proj-hero-content" style="position: absolute; top: 36%; left: 50%; transform: translate(-50%, -50%);">
        <h1
          class="text-3xl sm:text-5xl font-black"
          style="text-shadow: 3px 3px 0 #29cb17, -2px -2px 0 #0a4b09, 3px -2px 0 #406f40, -2px 3px 0 #75db77;"
        >
          Projects
        </h1>
      </div>

      <div style="position: absolute; bottom: 20%; left: 50%; transform: translateX(-50%);">
        <img
          src="/Billeder/PILNED.svg"
          alt="Scroll ned"
          class="w-10 transition-transform duration-700 hover:scale-110 cursor-pointer"
          onclick="const el = document.getElementById('projekter'); window.scrollTo({ top: el.offsetTop - 80, behavior: 'smooth' })"
        />
      </div>
    </div>

    <div id="projekter" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-8">

      <!-- GRUMS -->
<div class="rounded-2xl overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.9)] border border-[#272425] transition-all duration-500 fade-in flex flex-col">
        <div class="relative overflow-hidden h-75">
          <img src="/Billeder/GRUMS/GRUMSSTART.png" alt="GRUMS" class="w-full h-full object-cover" style="object-position: center 50%;" />
        </div>
        <div class="p-8 flex flex-col justify-between bg-black/80 flex-1">
          <h2 class="text-3xl font-bold text-[#29cb17] mb-4">GRUMS - Asset generator</h2>
          <div class="space-y-3 text-base text-gray-200 leading-relaxed mb-6">
            <p><strong class="text-[#29cb17]">GRUMS - Asset generator</strong> A branding project in which I conceptualized and built the tea and coffee brand GRUMS from the ground up, including a complete visual identity and a custom asset generator.</p>
          </div>
          <a href="/GRUMS" class="inline-block bg-[#29cb17] hover:bg-lime-700 text-white font-bold py-3 px-6 rounded-xl transition-all duration-300 transform hover:scale-105 w-fit">Read More</a>
        </div>
      </div>

      <!-- SHE CAN PLAY -->
<div class="rounded-2xl overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.9)] border border-[#272425] transition-all duration-500 fade-in flex flex-col">
        <div class="relative overflow-hidden h-75">
          <img src="/Billeder/SHECANPLAY/SHECANPLAYSTART.png" alt="SHE CAN PLAY" class="w-full h-full object-cover" style="object-position: center 80%;" />
        </div>
<div class="p-8 flex flex-col justify-between bg-black/80 flex-1">
          <h2 class="text-3xl font-bold text-[#29cb17] mb-4">SHE CAN PLAY</h2>
          <div class="space-y-3 text-base text-gray-200 leading-relaxed mb-6">
            <p><strong class="text-[#29cb17]">SHE CAN PLAY</strong>A branding and identity project focused on developing a new visual language, including a tone generator for creating cohesive visuals and album covers.</p>
          </div>
          <a href="/SHECANPLAY" class="inline-block bg-[#29cb17] hover:bg-lime-700 text-white font-bold py-3 px-6 rounded-xl transition-all duration-300 transform hover:scale-105 w-fit">Read More</a>
        </div>
      </div>

      <!-- AABEN -->
      <div class="rounded-2xl overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.9)] border border-[#272425] transition-all duration-500 fade-in flex flex-col">
        <div class="relative overflow-hidden h-75">
          <img src="/Billeder/AABEN/AABENSTART.png" alt="AABEN" class="w-full h-full object-cover" style="object-position: center 49%; " />
        </div>
        <div class="p-8 flex flex-col justify-between bg-black/80 flex-1">
          <h2 class="text-3xl font-bold text-[#29cb17] mb-4">AABEN - Label generator</h2>
          <div class="space-y-3 text-base text-gray-200 leading-relaxed mb-6">
            <p><strong class="text-[#29cb17]">AABEN - Label generator</strong> is a label generator designed to streamline the creation of unique and distinctive labels for an expanding craft beer collection.</p>
          </div>
          <a href="/AABEN" class="inline-block bg-[#29cb17] hover:bg-lime-700 text-white font-bold py-3 px-6 rounded-xl transition-all duration-300 transform hover:scale-105 w-fit">Read More</a>
        </div>
      </div>

      <!-- Havet under press -->
   <div class="rounded-2xl overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.9)] border border-[#272425] transition-all duration-500 fade-in flex flex-col">
        <div class="relative overflow-hidden h-75">
          <img src="/Billeder/VIDEN/VIDENSTART.jpg" alt="Project 4" class="w-full h-full object-contain bg-[#DFE3DC]" />
        </div>
        <div class="p-8 flex flex-col justify-between bg-black/80 flex-1">
          <h2 class="text-3xl font-bold text-[#29cb17] mb-4">Havet under press</h2>
          <div class="space-y-3 text-base text-gray-200 leading-relaxed mb-6">
            <p><strong class="text-[#29cb17]">Havet under press</strong> An educational web game created in collaboration with Videnskab.dk, using interactive gameplay to teach children about the damaging effects of pollution on our oceans and beaches.</p>
          </div>
          <a href="/VIDEN" class="inline-block bg-[#29cb17] hover:bg-lime-700 text-white font-bold py-3 px-6 rounded-xl transition-all duration-300 transform hover:scale-105 w-fit">Read More</a>
        </div>
      </div>

      <!-- MetroWars -->
   <div class="rounded-2xl overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.9)] border border-[#272425] transition-all duration-500 fade-in flex flex-col">
        <div class="relative overflow-hidden h-75">
          <img src="/Billeder/METRO/METROSTART.png" alt="Project 5" class="w-full h-full object-contain bg-[#322E56] scale-103" />
        </div>
        <div class="p-8 flex flex-col justify-between bg-black/80 flex-1">
          <h2 class="text-3xl font-bold text-[#29cb17] mb-4">MetroWars</h2>
          <div class="space-y-3 text-base text-gray-200 leading-relaxed mb-6">
            <p><strong class="text-[#29cb17]">MetroWars</strong> is A game design project developed in collaboration with Sikkertrafik.dk, aimed at promoting safe habits and raising awareness of the dangers of cycling drunk.</p>
          </div>
          <a href="/METRO" class="inline-block bg-[#29cb17] hover:bg-lime-700 text-white font-bold py-3 px-6 rounded-xl transition-all duration-300 transform hover:scale-105 w-fit">Read More</a>
        </div>
      </div>

      <!-- Fez Morocco City branding-->
<div class="rounded-2xl overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.9)] border border-[#272425] transition-all duration-500 fade-in flex flex-col">
        <div class="relative overflow-hidden h-75">
          <img src="/Billeder/FEZ/FEZSTART.jpg" alt="Project 6" class="w-full h-full object-contain bg-black/60" />
        </div>
        <div class="p-8 flex flex-col justify-between bg-black/80 flex-1">
          <h2 class="text-3xl font-bold text-[#29cb17] mb-4">Fez Morocco City branding</h2>
          <div class="space-y-3 text-base text-gray-200 leading-relaxed mb-6">
            <p><strong class="text-[#29cb17]">Fez Morocco City branding</strong> A branding project focused on developing a distinctive visual element that can serve as a recognizable symbol for the city of Fez.</p>
          </div>
          <a href="/" class="inline-block bg-[#29cb17] hover:bg-lime-700 text-white font-bold py-3 px-6 rounded-xl transition-all duration-300 transform hover:scale-105 w-fit">Read More</a>
        </div>
      </div>

    </div>

    <footer class="site-footer mt-10">
      <div class="footer-box">
        <p>© Lærke Buch Nonved portfolio</p>
      </div>
    </footer>

  </div>

</Layout>