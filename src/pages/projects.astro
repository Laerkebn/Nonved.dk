---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Projects | My Portfolio" page="projects">

  <div class="page-wrapper">

    <!-- HERO -->
    <div class="proj-hero fade-in" style="min-height: 60vh;">
      <div class="proj-title">PROJECTS</div>
    </div>

    <div id="projekter" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-8 -mt-52">

      <!-- GRUMS -->
      <a href="/GRUMS" class=" overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.9)] border border-[#272425] transition-all duration-500 fade-in flex flex-col hover:scale-[1.02]">
        <div class="relative overflow-hidden h-75">
          <img src="/Billeder/GRUMS/GRUMSSTART.png" alt="GRUMS" class="w-full h-full object-cover" style="object-position: center 50%;" />
        </div>
        <div class="p-8 flex flex-col justify-between bg-black/80 flex-1">
          <h2 class="text-3xl font-bold text-[#29cb17] mb-4">GRUMS - Asset generator</h2>
          <div class="space-y-3 text-base text-gray-200 leading-relaxed">
            <p><strong class="text-[#29cb17]">GRUMS - Asset generator</strong> A branding project in which I conceptualized and built the tea and coffee brand GRUMS from the ground up, including a complete visual identity and a custom asset generator.</p>
          </div>
        </div>
      </a>

      <!-- SHE CAN PLAY -->
      <a href="/SHECANPLAY" class=" overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.9)] border border-[#272425] transition-all duration-500 fade-in flex flex-col hover:scale-[1.02]">
        <div class="relative overflow-hidden h-75">
          <img src="/Billeder/SHECANPLAY/SHECANPLAYSTART.png" alt="SHE CAN PLAY" class="w-full h-full object-cover" style="object-position: center 80%;" />
        </div>
        <div class="p-8 flex flex-col justify-between bg-black/80 flex-1">
          <h2 class="text-3xl font-bold text-[#29cb17] mb-4">SHE CAN PLAY</h2>
          <div class="space-y-3 text-base text-gray-200 leading-relaxed">
            <p><strong class="text-[#29cb17]">SHE CAN PLAY</strong> A branding and identity project focused on developing a new visual language, including a tone generator for creating cohesive visuals and album covers.</p>
          </div>
        </div>
      </a>

      <!-- AABEN -->
      <a href="/AABEN" class=" overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.9)] border border-[#272425] transition-all duration-500 fade-in flex flex-col hover:scale-[1.02]">
        <div class="relative overflow-hidden h-75">
          <img src="/Billeder/AABEN/AABENSTART.png" alt="AABEN" class="w-full h-full object-cover" style="object-position: center 49%;" />
        </div>
        <div class="p-8 flex flex-col justify-between bg-black/80 flex-1">
          <h2 class="text-3xl font-bold text-[#29cb17] mb-4">ÅBEN - Label generator</h2>
          <div class="space-y-3 text-base text-gray-200 leading-relaxed">
            <p><strong class="text-[#29cb17]">ÅBEN - Label generator</strong> A label generator designed to streamline the creation of unique and distinctive labels for an expanding craft beer collection.</p>
          </div>
        </div>
      </a>

      <!-- Havet under press -->
      <a href="/VIDEN" class=" overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.9)] border border-[#272425] transition-all duration-500 fade-in flex flex-col hover:scale-[1.02]">
        <div class="relative overflow-hidden h-75">
          <img src="/Billeder/VIDEN/VIDENSTART.jpg" alt="Project 4" class="w-full h-full object-contain bg-[#DFE3DC]" />
        </div>
        <div class="p-8 flex flex-col justify-between bg-black/80 flex-1">
          <h2 class="text-3xl font-bold text-[#29cb17] mb-4">Havet under press</h2>
          <div class="space-y-3 text-base text-gray-200 leading-relaxed">
            <p><strong class="text-[#29cb17]">Havet under press</strong> An educational web game created in collaboration with Videnskab.dk, using interactive gameplay to teach children about the damaging effects of pollution on our oceans and beaches.</p>
          </div>
        </div>
      </a>

      <!-- MetroWars -->
      <a href="/METRO" class=" overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.9)] border border-[#272425] transition-all duration-500 fade-in flex flex-col hover:scale-[1.02]">
        <div class="relative overflow-hidden h-75">
          <img src="/Billeder/METRO/METROSTART.png" alt="Project 5" class="w-full h-full object-contain bg-[#322E56] scale-103" />
        </div>
        <div class="p-8 flex flex-col justify-between bg-black/80 flex-1">
          <h2 class="text-3xl font-bold text-[#29cb17] mb-4">MetroWars</h2>
          <div class="space-y-3 text-base text-gray-200 leading-relaxed">
            <p><strong class="text-[#29cb17]">MetroWars</strong> A game design project developed in collaboration with Sikkertrafik.dk, aimed at promoting safe habits and raising awareness of the dangers of cycling drunk.</p>
          </div>
        </div>
      </a>

      <!-- Fez Morocco City branding -->
      <a href="/FEZ" class=" overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.9)] border border-[#272425] transition-all duration-500 fade-in flex flex-col hover:scale-[1.02]">
        <div class="relative overflow-hidden h-75">
          <img src="/Billeder/FEZ/FEZSTART.jpg" alt="Project 6" class="w-full h-full object-contain bg-black/60" />
        </div>
        <div class="p-8 flex flex-col justify-between bg-black/80 flex-1">
          <h2 class="text-3xl font-bold text-[#29cb17] mb-4">Fez Morocco City branding</h2>
          <div class="space-y-3 text-base text-gray-200 leading-relaxed">
            <p><strong class="text-[#29cb17]">Fez Morocco City branding</strong> A branding project focused on developing a distinctive visual element that can serve as a recognizable symbol for the city of Fez.</p>
          </div>
        </div>
      </a>

    </div>

    <footer class="site-footer -mt-20">
      <div class="footer-box">
        <p>© Lærke Buch Nonved portfolio</p>
      </div>
    </footer>

  </div>

</Layout>