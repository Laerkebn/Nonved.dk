---
import { ClientRouter } from 'astro:transitions';
const { title = 'My Portfolio', page = '' } = Astro.props;
import '../styles/global.css';

const isStaticPage = page === 'about' || page === 'projects';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Simple portfolio website built with Astro" />
    <title>{title}</title>
    <ClientRouter />
  </head>

  <body>
    <!-- Background videos -->
    <video
      id="bg-video-1"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      class="bg-video active"
      transition:persist
    >
      <source src="/Videoer/BagrundPositivLOW80.mp4" type="video/mp4" />
    </video>

    <video
      id="bg-video-2"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      class="bg-video hidden"
      transition:persist
    >
      <source src="/Videoer/BagrundNegativLOW80.mp4" type="video/mp4" />
    </video>

    <!-- Mørk overlay på about/projects (z-index 5 = mellem video (-10) og indhold (10)) -->
    {isStaticPage && (
      <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.70); z-index: 5;"></div>
    )}

    <audio id="bg-audio" loop>
      <source src="/music/fugle.mp3" type="audio/mp3" />
    </audio>

    <!-- Top navigation -->
    <header class="top-bar">
      <nav
        class="text-xs sm:text-sm md:text-base lg:text-xl bar-box bg-[#272425]/80 text-[#29cb17] flex justify-evenly w-full uppercase tracking-widest font-semibold"
        style="text-shadow: 2px 2px 0 #000, -2px -2px 0 #000, 2px -2px 0 #000, -2px 2px 0 #000, 2px 0 0 #000, -2px 0 0 #000, 0 2px 0 #000, 0 -2px 0 #000;"
      >
        <a href="/" class="hover:text-purple-600 transition duration-300 hover:scale-110">
          Frontpage
        </a>
        <a href="/about" class="hover:text-purple-600 transition duration-300 hover:scale-110">
          About
        </a>
        <a href="/projects" class="hover:text-purple-600 transition duration-300 hover:scale-110">
          Projects
        </a>
        <a href="/contact" class="hover:text-purple-600 transition duration-300 hover:scale-110">
          Contact
        </a>
      </nav>
    </header>

    <!-- Main page area -->
    <main class="page-content">
      <slot />
    </main>
    
    <!-- Bottom bar -->
    <div class="bottom-bar">
      <div class="bar-box bottom-inner bg-[#272425]/80 text-xs sm:text-sm md:text-base lg:text-xl">

        <button
          id="toggle-btn"
          onclick="toggleBackgroundVideo()"
          class="text-[#29cb17] p-2 uppercase tracking-widest font-semibold hover:text-purple-600 transition duration-300 hover:scale-110"
          style="text-shadow: 2px 2px 0 #000, -2px -2px 0 #000, 2px -2px 0 #000, -2px 2px 0 #000, 2px 0 0 #000, -2px 0 0 #000, 0 2px 0 #000, 0 -2px 0 #000;"
        >
          Lights off
        </button>

        <button
          id="toggle-soundbtn"
          onclick="toggleSound()"
          class="text-[#29cb17] p-2 uppercase tracking-widest font-semibold hover:text-purple-600 transition duration-300 hover:scale-110"
          style="text-shadow: 2px 2px 0 #000, -2px -2px 0 #000, 2px -2px 0 #000, -2px 2px 0 #000, 2px 0 0 #000, -2px 0 0 #000, 0 2px 0 #000, 0 -2px 0 #000;"
        >
          Sound off
        </button>

        <button
          id="toggle-languagebtn"
          class="text-[#29cb17] p-2 uppercase tracking-widest font-semibold hover:text-purple-600 transition duration-300 hover:scale-110"
          style="text-shadow: 2px 2px 0 #000, -2px -2px 0 #000, 2px -2px 0 #000, -2px 2px 0 #000, 2px 0 0 #000, -2px 0 0 #000, 0 2px 0 #000, 0 -2px 0 #000;"
        >
          English
        </button>

      </div>
    </div>

    <script is:inline>
      const video1 = document.getElementById('bg-video-1');
      const video2 = document.getElementById('bg-video-2');

      let showingFirst = true;

      window.toggleBackgroundVideo = async () => {
        const button = document.getElementById('toggle-btn');
        if (!video1 || !video2) return;

        const currentVideo = showingFirst ? video1 : video2;
        const nextVideo = showingFirst ? video2 : video1;

        nextVideo.currentTime = currentVideo.currentTime;

        try {
          await nextVideo.play();
        } catch (error) {
          console.error('Kunne ikke starte næste video:', error);
        }

        currentVideo.classList.remove('active');
        currentVideo.classList.add('hidden');

        nextVideo.classList.remove('hidden');
        nextVideo.classList.add('active');

        if (button) {
          button.textContent = showingFirst ? 'Lights on' : 'Lights off';
        }

        showingFirst = !showingFirst;
      };

      // Lydkontrol
      const audio = document.getElementById('bg-audio');
      let audioPlaying = false;

      document.addEventListener('click', () => {
        if (!audioPlaying) {
          audio.play();
          audioPlaying = true;
          document.getElementById('toggle-soundbtn').textContent = 'Sound off';
        }
      }, { once: true });

      window.toggleSound = () => {
        const button = document.getElementById('toggle-soundbtn');
        if (!audio) return;

        if (audioPlaying) {
          audio.pause();
          button.textContent = 'Sound on';
        } else {
          audio.play();
          button.textContent = 'Sound off';
        }

        audioPlaying = !audioPlaying;
      };

     // Fade-in for alle sider
function initFadeIn() {
  const fadeEls = document.querySelectorAll('.fade-in');
 const observer = new IntersectionObserver((entries) => {
  entries.forEach(el => {
    if (el.isIntersecting) el.target.classList.add('visible');
  });
}, { threshold: 0 });
  fadeEls.forEach(el => observer.observe(el));
}
document.addEventListener('astro:page-load', initFadeIn);
setTimeout(initFadeIn, 50);
    </script>

  </body>
</html>